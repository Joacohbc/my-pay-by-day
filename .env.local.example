# ==============================================================================
# My Pay By Day - Local Development Environment Configuration (.env.local.example)
#
# Copy this file to `.env.local` or `.env` for local development (outside Docker
# or when running via `docker-compose.local.yml` / local dev servers).
# ==============================================================================

# ── Required Keys for Local Dev ───────────────────────────────────────────────
# Must be at least 32 characters for AES-256 field encryption.
DB_FIELD_ENCRYPTION_KEY=local-dev-db-encryption-key-32-chars-minimum!

# OpenRouter API key for local AI chatbot service testing.
OPENROUTER_API_KEY=your-openrouter-api-key

# ── AI Configuration (Node Chatbot: Vercel AI SDK + OpenRouter) ───────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Large multimodal model (chat, vision, complex reasoning)
MODEL_LARGE=google/gemini-2.5-flash

# Fast/cheap model (quick actions, extraction structuring)
MODEL_FAST=google/gemini-flash-lite

# Dedicated speech-to-text model (voice receipt/audio input)
MODEL_AUDIO=openai/whisper-large-v3-turbo

# ── Agent Limits ──────────────────────────────────────────────────────────────
AGENT_MAX_STEPS=25
SUBAGENT_MAX_STEPS=12
AGENT_MAX_CHAT_MESSAGES=150

# ── Database (Local paths) ────────────────────────────────────────────────────
# Relative paths for running directly on host system:
QUARKUS_DATASOURCE_JDBC_URL=jdbc:sqlite:./data/backend/mypaybyday.db
CHATBOT_DB_PATH=./data/chatbot/chatbot.db

# ── Backend Configuration ─────────────────────────────────────────────────────
TZ=UTC
APP_LOG_LEVEL=DEBUG
MYPAYBYDAY_FILES_MAX_SIZE=10485760
MYPAYBYDAY_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ── Frontend Configuration (Vite Dev Server) ──────────────────────────────────
VITE_API_BASE_URL=/api
VITE_LOG_LEVEL=debug

# ── Chatbot Logging & Node Environment ────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_MAX_FIELD_CHARS=800
LOG_TIMESTAMPS=true
BACKEND_URL=http://localhost:8080

# ── Local Builds & Observability (docker-compose.local.yml) ───────────────────
GIT_SHA=dev
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000/
