# ── Required ──────────────────────────────────────────────
# Must be exactly 32 bytes (or longer) for AES-256 encryption.
DB_FIELD_ENCRYPTION_KEY=your-encryption-key-longer-than-32-chars
OPENROUTER_API_KEY=your-openrouter-api-key

# ── AI (Node chatbot service: Vercel AI SDK + OpenRouter) ──
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Large multimodal model (chat + agent + image understanding)
MODEL_LARGE=xiaomi/mimo-v2.5

# Fast/cheap model (text actions, extraction structuring, summarisation)
MODEL_FAST=openai/gpt-oss-120b

# Dedicated speech-to-text model, called via OpenRouter's /audio/transcriptions endpoint
MODEL_AUDIO=mistralai/voxtral-mini-transcribe

# ── Agent Limits (optional — defaults shown) ──────────────
# Maximum tool-calling steps per agent run before the loop stops
AGENT_MAX_STEPS=25

# Maximum tool-calling steps per in-turn sub-agent delegation before it stops
SUBAGENT_MAX_STEPS=12

# Maximum conversation messages kept before compaction kicks in
AGENT_MAX_CHAT_MESSAGES=150

# ── Database ────────────────────────────────────────────────
# Note: For Docker, use absolute path `/data/mypaybyday.db` (which maps to the backend_data volume).
# For local development (outside Docker), use a relative path like `mypaybyday.db`.
# PRAGMAs (WAL, timeout) are already configured in application.properties, no need to add them here.
QUARKUS_DATASOURCE_JDBC_URL=jdbc:sqlite:/data/mypaybyday.db
CHATBOT_DB_PATH=/data/chatbot.db

# ── Files (optional — defaults shown) ─────────────────────
# MYPAYBYDAY_FILES_MAX_SIZE=10485760

# ── Backend Server (optional — defaults shown) ────────────
# TZ=UTC
# APP_LOG_LEVEL=INFO
# CORS allowed origins in prod (empty = same-origin only, behind nginx).
# Example: https://app.midominio.com
# MYPAYBYDAY_CORS_ORIGINS=

# ── Frontend (optional) ───────────────────────────────────
# VITE_API_BASE_URL=/api
# Client logger verbosity: silent | error | warn | info | debug | trace (unified default: info)
# VITE_LOG_LEVEL=info

# ── Chatbot Logging (optional — defaults shown) ───────────
# LOG_LEVEL=info
# LOG_FORMAT=json
# LOG_MAX_FIELD_CHARS=800
# LOG_TIMESTAMPS=true
# NODE_ENV=production

# ── Ingress: Cloudflare Tunnel (required in prod) ─────────
# docker-compose.yml publishes no host ports; the tunnel is the only way in.
# Token of a remotely-managed tunnel, from Zero Trust > Networks > Tunnels.
# Treat it as a secret: it is enough on its own to serve traffic for the tunnel.
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ── Observability ─────────────────────────────────────────
# Grafana has no published port; it is served by the gateway under /grafana/,
# so it is reachable by anyone who can reach the app. Change these credentials
# and put a Cloudflare Access policy on /grafana/* before going live.
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
# Public URL of the sub-path; wrong value breaks Grafana's redirects and assets.
# GRAFANA_ROOT_URL=https://app.midominio.com/grafana/

# ── Local builds only (docker-compose.local.yml) ──────────
# Commit SHA stamped into the frontend build; ignored by docker-compose.yml.
# GIT_SHA=dev
