# ── Required ──────────────────────────────────────────────
# Must be exactly 32 bytes (or longer) for AES-256 encryption.
DB_FIELD_ENCRYPTION_KEY=your-encryption-key-longer-than-32-chars
OPENROUTER_API_KEY=your-openrouter-api-key

# ── AI (Node chatbot service: Vercel AI SDK + OpenRouter) ──
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Large multimodal model (chat + agent + image understanding)
MODEL_LARGE=xiaomi/mimo-v2.5

# Fast/cheap model (text actions, extraction structuring, summarisation)
MODEL_FAST=openai/gpt-oss-120b

# Dedicated speech-to-text model, called via OpenRouter's /audio/transcriptions endpoint
MODEL_AUDIO=mistralai/voxtral-mini-transcribe

# ── Agent Limits (optional — defaults shown) ──────────────
# Maximum tool-calling steps per agent run before the loop stops
AGENT_MAX_STEPS=500

# Maximum tool-calling steps per in-turn sub-agent delegation before it stops
SUBAGENT_MAX_STEPS=12

# Maximum conversation messages kept before compaction kicks in
AGENT_MAX_CHAT_MESSAGES=150

# ── Database ────────────────────────────────────────────────
# Note: For Docker, use absolute path `/data/mypaybyday.db` (which maps to the db_data volume).
# For local development (outside Docker), use a relative path like `mypaybyday.db`.
# PRAGMAs (WAL, timeout) are already configured in application.properties, no need to add them here.
QUARKUS_DATASOURCE_JDBC_URL=jdbc:sqlite:/data/mypaybyday.db
CHATBOT_DB_PATH=/data/chatbot.db

# ── Files (optional — defaults shown) ─────────────────────
# MYPAYBYDAY_FILES_MAX_SIZE=10485760

# ── Server (optional) ─────────────────────────────────────
# TZ=UTC

# ── Frontend (optional) ───────────────────────────────────
# VITE_API_BASE_URL=/api

# ── Chatbot Logging (optional — defaults shown) ───────────
# LOG_LEVEL=debug
# LOG_FORMAT=text
# LOG_MAX_FIELD_CHARS=800
# LOG_TIMESTAMPS=true
