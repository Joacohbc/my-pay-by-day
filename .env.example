# ── Required ──────────────────────────────────────────────
DB_FIELD_ENCRYPTION_KEY=your-encryption-key-longer-than-32-chars
OPENROUTER_API_KEY=your-openrouter-api-key

# ── AI (Node chatbot service: Vercel AI SDK + OpenRouter) ──
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Large multimodal model (chat + agent + image/audio understanding)
MODEL_LARGE=google/gemini-flash-3.5
# Fast/cheap model (text actions, extraction structuring, summarisation)
MODEL_FAST=google/gemini-flash-lite
# Max tool-calling steps per agent run (optional)
# AGENT_MAX_STEPS=25

# ── Database (optional — defaults shown) ──────────────────
# QUARKUS_DATASOURCE_JDBC_URL=jdbc:sqlite:/data/mypaybyday.db
# CHATBOT_DB_PATH=/data/chatbot.db

# ── Server (optional) ─────────────────────────────────────
# TZ=UTC

# ── Frontend (optional) ───────────────────────────────────
# VITE_API_BASE_URL=/api
