{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug Backend",
			"type": "java",
			"request": "attach",
			"hostName": "localhost",
			"port": 5005,
			"projectName": "mypaybyday",
			"preLaunchTask": "quarkus:dev"
		},
		{
			"name": "Debug Frontend",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["dev", "--host"],
			"cwd": "${workspaceFolder}/frontend",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"name": "Debug Chatbot",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["dev", "--host"],
			"cwd": "${workspaceFolder}/chatbot",
			"envFile": "${workspaceFolder}/chatbot/.env",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"name": "Run Markitdown",
			"type": "node-terminal",
			"request": "launch",
			"command": "./run.sh",
			"cwd": "/workspace/docker/markitdown"
		}
	]
}
