# Base URL for the backend API.
# In Docker, this is a RUNTIME environment variable injected by entrypoint.sh
# into /env.js, which the app reads from window.__env__.
# In dev (pnpm dev), keep it as /api so Vite's proxy correctly routes
# /api/ai & /api/agent-tasks to Chatbot, and /api/* to Backend.
VITE_API_BASE_URL=/api

# Verbosity threshold for the client logger: silent | error | warn | info | debug | trace
# Unified with the backend (APP_LOG_LEVEL) and chatbot (LOG_LEVEL); default is info.
# Injected at runtime into /env.js in Docker; read from this file in dev.
VITE_LOG_LEVEL=info
