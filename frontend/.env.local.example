# Local development overrides for Vite frontend
VITE_LOG_LEVEL=debug

# Keep VITE_API_BASE_URL as /api so Vite's proxy routes /api/ai & /api/agent-tasks -> Chatbot and /api/* -> Backend
VITE_API_BASE_URL=/api

# Optional: Override local dev proxy target ports if running backend/chatbot on custom ports
# CHATBOT_PORT=3001
# BACKEND_PORT=8080
