# Local development environment overrides for Chatbot
CHATBOT_PORT=3001
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_LARGE=xiaomi/mimo-v2.5
MODEL_FAST=openai/gpt-oss-120b
MODEL_AUDIO=mistralai/voxtral-mini-transcribe
BACKEND_URL=http://127.0.0.1:8080
CHATBOT_DB_PATH=./chatbot.db
AGENT_MAX_STEPS=25
SUBAGENT_MAX_STEPS=12
AGENT_MAX_CHAT_MESSAGES=150
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_MAX_FIELD_CHARS=800
LOG_TIMESTAMPS=true
NODE_ENV=development
