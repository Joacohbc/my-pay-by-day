{
  "name": "mypaybyday-chatbot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI chatbot/agent service for My Pay By Day (Vercel AI SDK + OpenRouter)",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "gen:api": "openapi-typescript ../mypaybyday/target/openapi/openapi.json -o src/backend/schema.d.ts",
    "gen:api:check": "pnpm gen:api && git diff --exit-code src/backend/schema.d.ts",
    "gen:tools": "tsx scripts/generate-tool-manifest.ts",
    "gen:tools:check": "pnpm gen:tools && git diff --exit-code ../frontend/src/lib/chat/toolManifest.generated.ts",
    "i18n:audit": "node scripts/i18n-audit.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "ai": "^6.0.224",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "hono": "^4.12.29",
    "openapi-fetch": "^0.17.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "openapi-typescript": "^7.13.0",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3"
  }
}
