# ── Server ────────────────────────────────────────────────
CHATBOT_PORT=3001

# ── OpenRouter (LLM provider) ─────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models used via OpenRouter
# Large multimodal model (chat + agent + image understanding)
MODEL_LARGE=google/gemini-2.5-flash

# Fast/cheap model (text actions, extraction structuring, summarisation)
MODEL_FAST=google/gemini-flash-lite

# Dedicated speech-to-text model, called via OpenRouter's /audio/transcriptions endpoint
MODEL_AUDIO=openai/whisper-large-v3-turbo

# ── Backend ───────────────────────────────────────────────
# Java (Quarkus) domain backend the tools call into
BACKEND_URL=http://127.0.0.1:8080

# ── Database ──────────────────────────────────────────────
# SQLite storage
CHATBOT_DB_PATH=./chatbot.db

# ── Agent Limits ──────────────────────────────────────────
# Maximum tool-calling steps per agent run before the loop stops
AGENT_MAX_STEPS=25
# Maximum tool-calling steps per in-turn sub-agent delegation before it stops
SUBAGENT_MAX_STEPS=12
# Maximum conversation messages kept before compaction kicks in
AGENT_MAX_CHAT_MESSAGES=150

# ── Logging ───────────────────────────────────────────────

# Verbosity threshold: silent | error | warn | info | debug | trace
LOG_LEVEL=debug

# Output format: 'text' (human-readable) or 'json' (structured, one object per line).
# Defaults to 'json' when NODE_ENV=production, otherwise 'text'. This var overrides that default.
LOG_FORMAT=text

# Max characters per logged field value before truncation
LOG_MAX_FIELD_CHARS=800

# Prefix each line with an ISO timestamp (text format only)
LOG_TIMESTAMPS=true

# ── Runtime ───────────────────────────────────────────────

# 'production' switches the default log format to JSON for auditing/aggregation (Loki/Grafana)
NODE_ENV=production
