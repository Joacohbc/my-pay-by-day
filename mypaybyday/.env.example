#  A secret key used for encrypting sensitive fields in the database. It should be a long, random string.
DB_FIELD_ENCRYPTION_KEY="contraseña-secreta-para-encriptar-campos-de-la-db"

# JDBC URL for the SQLite database. The default points to a file named mypaybyday.db in the /work/data directory (docker volume).
# QUARKUS_DATASOURCE_JDBC_URL="jdbc:sqlite:/work/data/mypaybyday.db"

# Ollama server base URL.
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model ID to use.
OLLAMA_MODEL_ID=gemma3:1b-it-qat

# Ollama embedding model to use.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# RAG storage path inside the container.
RAG_STORAGE_PATH=/work/data/rag-vectors.json
