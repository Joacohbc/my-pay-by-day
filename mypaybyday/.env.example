# ── Required ──────────────────────────────────────────────
DB_FIELD_ENCRYPTION_KEY=your-encryption-key-longer-than-32-chars
OPENROUTER_API_KEY=your-openrouter-api-key

# ── AI Models ─────────────────────────────────────────────
BASE_URL=https://openrouter.ai/api/v1
AI_PRIMARY_MODEL=stepfun/step-3.5-flash:free
AI_VISION_MODEL=google/gemma-3-27b-it:free
AI_AUDIO_MODEL=google/gemini-3.1-flash-lite-preview
AI_AGENT_MODEL=google/gemini-3-flash-preview

# ── AI Timeouts (optional — defaults shown) ───────────────
# AI_PRIMARY_TIMEOUT=60
# AI_VISION_TIMEOUT=180
# AI_AUDIO_TIMEOUT=60
# AI_AGENT_TIMEOUT=600

# ── Database (optional — defaults shown) ──────────────────
# QUARKUS_DATASOURCE_JDBC_URL=jdbc:sqlite:/data/mypaybyday.db

# ── Server (optional) ─────────────────────────────────────
# TZ=UTC
