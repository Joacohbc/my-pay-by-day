#  A secret key used for encrypting sensitive fields in the database. It should be a long, random string.
DB_FIELD_ENCRYPTION_KEY="contraseña-secreta-para-encriptar-campos-de-la-db"

# JDBC URL for the SQLite database. The default points to a file named mypaybyday.db in the /data directory.
# QUARKUS_DATASOURCE_JDBC_URL="jdbc:sqlite:/data/mypaybyday.db"

# Comma-separated list of allowed CORS origins. Add every domain that the frontend will be served from.
# Maps directly to quarkus.http.cors.origins — preferred over CORS_ORIGINS to avoid indirection.
# Example: QUARKUS_HTTP_CORS_ORIGINS=http://localhost:5173,https://app.mypaybyday.com
QUARKUS_HTTP_CORS_ORIGINS="http://localhost:5173"