# ── Encryption ────────────────────────────────────────────
# Required in PROD (startup aborts if missing). Optional in DEV: if unset, it falls back
# to an insecure development default. Must be 32+ bytes for AES-256 encryption.
# DB_FIELD_ENCRYPTION_KEY=your-encryption-key-longer-than-32-chars

# ── Database (optional — defaults shown) ──────────────────
# Note: For local development, use a relative path like `mypaybyday.db`.
# If deploying in Docker, use an absolute path like `/data/mypaybyday.db`.
# PRAGMAs (WAL, timeout) are already configured in application.properties, no need to add them here.
# QUARKUS_DATASOURCE_JDBC_URL=jdbc:sqlite:mypaybyday.db

# ── Files (optional — defaults shown) ─────────────────────
# MYPAYBYDAY_FILES_MAX_SIZE=10485760

# ── Server (optional — defaults shown) ────────────────────
# TZ=UTC