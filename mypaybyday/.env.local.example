# ==============================================================================
# Backend (Quarkus) - Local Development Configuration (.env.local.example)
#
# Copy this file to `.env.local` or `.env` inside `mypaybyday/` for local backend development
# (when running `./mvnw quarkus:dev` or executing local backend services).
# ==============================================================================

# ── Encryption ────────────────────────────────────────────
# Must be at least 32 bytes for AES-256 field encryption.
# %dev profile falls back to default if unset, but specifying it here guarantees key consistency.
DB_FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── Database ──────────────────────────────────────────────
# Relative path to SQLite database for local development.
QUARKUS_DATASOURCE_JDBC_URL=jdbc:sqlite:mypaybyday.db

# ── Server & Logging ──────────────────────────────────────
# System default timezone
TZ=UTC

# Log level for com.mypaybyday packages: TRACE | DEBUG | INFO | WARN | ERROR
APP_LOG_LEVEL=DEBUG

# Max allowed upload size in bytes (10MB default)
MYPAYBYDAY_FILES_MAX_SIZE=10485760

# ── CORS ──────────────────────────────────────────────────
# Allowed origins for local dev frontend
MYPAYBYDAY_CORS_ORIGINS=http://localhost:5173

# ── MarkItDown sidecar ────────────────────────────────────
# URL of local MarkItDown text extraction sidecar service
MARKITDOWN_URL=http://localhost:8590
