    {
      "id": 14,
      "title": "Heartbeat liveness (fixed rate \u2014 a gap is real, not just idle traffic)",
      "type": "state-timeline",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "description": "Backend and chatbot each emit one line per minute whether or not anyone is using the app. That fixed rate is the point: the traffic panels above cannot tell 'down' from 'nobody used it'. A gap here means the process is gone, wedged, or the log pipeline broke \u2014 it cannot separate those without an independent prober, which does not exist. gateway, frontend and markitdown have no runtime to emit a heartbeat; for those, the upstream failures below are the availability signal. Deliberately ignores $service so it never hides a service by filtering it out.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "mergeValues": true,
        "showValue": "never",
        "alignValue": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({service=\"backend\", source=\"heartbeat\"} [2m]))",
          "legendFormat": "backend"
        },
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({service=\"chatbot\"} | event=\"heartbeat\" [2m]))",
          "legendFormat": "chatbot"
        }
      ]
    },
