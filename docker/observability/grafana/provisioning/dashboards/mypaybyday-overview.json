{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "My Pay By Day — Logs",
  "uid": "mypaybyday-overview",
  "tags": ["mypaybyday"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Log volume by level (per 5m)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({job=\"docker\"} | json [5m]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\"} | json | level =~ `(?i)error`"
        }
      ]
    },
    {
      "id": 3,
      "title": "Application logs (filter by requestId with: | json | requestId=`...`)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\"}"
        }
      ]
    }
  ]
}
